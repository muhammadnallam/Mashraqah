
generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// UUID is chosen over CUID2 to leverage the native support and database optimization.
// Additionally, the platform manages articles URLs with slugs not with IDs (CUID2's main benefit).

model User {
  id          String   @id @default(uuid()) @db.Uuid
  email       String   @unique
  username    String   @unique
  bio         String?
  avatarUrl   String?
  preferences Json?
  createdAt   DateTime @default(now())

  articles      Article[]
  following     Follow[]   @relation("follower")
  followers     Follow[]   @relation("following")
  likes         Like[]
  bookmarks     Bookmark[]
  shares        Share[]
  views         View[]     @relation("userViews")
  
  name          String
  emailVerified Boolean    @default(false)
  image         String?
  updatedAt     DateTime   @updatedAt
  sessions      Session[]
  accounts      Account[]

  @@map("user")
}

model Article {
  id             String   @id @default(uuid()) @db.Uuid
  slug           String   @unique
  title          String
  subtitle       String
  seoTitle       String
  seoSubtitle    String
  topic          String
  coverImage     String
  content        Json
  searchVector   String?
  readTime       Int
  score          Float    @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  authorId String @db.Uuid
  author   User   @relation(fields: [authorId], references: [id])

  likes     Like[]
  bookmarks Bookmark[]
  shares    Share[]
  views     View[]       @relation("articleViews")
}

// Interactions were separated to simplify queries and make indexing more efficient.
// createdAt are recorded for a planned writer statistics feature.

model Follow {
  followerId  String   @db.Uuid
  followingId String   @db.Uuid
  follower    User     @relation("follower", fields: [followerId], references: [id])
  following   User     @relation("following", fields: [followingId], references: [id])
  createdAt   DateTime @default(now())

  @@id([followerId, followingId])
}

model Like {
  userId    String   @db.Uuid
  articleId String   @db.Uuid
  user      User     @relation(fields: [userId], references: [id])
  article   Article  @relation(fields: [articleId], references: [id])
  createdAt DateTime @default(now())

  @@id([userId, articleId])
}

model Bookmark {
  userId    String   @db.Uuid
  articleId String   @db.Uuid
  user      User     @relation(fields: [userId], references: [id])
  article   Article  @relation(fields: [articleId], references: [id])
  createdAt DateTime @default(now())

  @@id([userId, articleId])
}

model Share {
  userId    String   @db.Uuid
  articleId String   @db.Uuid
  user      User     @relation(fields: [userId], references: [id])
  article   Article  @relation(fields: [articleId], references: [id])
  createdAt DateTime @default(now())

  @@id([userId, articleId])
}

// Logged in views are counted once per user (@@unique), unlike unlimited guest views.

model View {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String?  @db.Uuid // Optional for counting guests views
  articleId String   @db.Uuid
  user      User?    @relation("userViews", fields: [userId], references: [id])
  article   Article  @relation("articleViews", fields: [articleId], references: [id])
  createdAt DateTime @default(now())

  // TODO: Add device type, browser, and location for analytics.

  @@unique([userId, articleId])
}

// TODO: model Comment (Manage threaded comments, nesting replies).

model Session {
  id        String   @id @default(uuid()) @db.Uuid
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String   @db.Uuid
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id @default(uuid()) @db.Uuid
  accountId             String
  providerId            String
  userId                String    @db.Uuid
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id @default(uuid()) @db.Uuid
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}
